datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  password  String
  role      String   // "ADMIN" | "CASHIER"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Product {
  id            String   @id @default(cuid())
  code          String   @unique // كود الصنف (مثال: 3020)
  barcode       String?  @unique // الباركود للبحث السريع باللمس أو القارئ
  name          String   // اسم المنتج (مثال: مواسير UPVC)
  type          String   // "PIPE" | "HOSE" | "ACCESSORY"
  gauge         String?  // السمك/الفئة (Light, Medium, Heavy, Extra Heavy)
  size          String   // المقاس (مثال: 20 mm)
  color         String?  // اللون
  length        String?  // الطول (مثال: 45 m)
  weight        String?  // الوزن (مثال: 5.050 kg)
  costPrice     Float    @default(0) // سعر التكلفة الفعلي للإنتاج (سعر الشراء)
  markup        Float    @default(1.3) // نسبة الربح المضاعف (يضرب في سعر التكلفة ليعطي سعر البيع)
  price         Float    // السعر الأساسي للبيع
  taxRate       Float    @default(0.14) // ضريبة القيمة المضافة (14% أو 15%)
  stockQty      Int      @default(0) // كمية المخزون الحالي
  minStockQty   Int      @default(10) // التنبيه باللون الأحمر عند الوصول لهذا الحد (الحد الأدنى)
  maxStockQty   Int      @default(1000) // الحد الأقصى للمخزون
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderItems    OrderItem[]
  purchaseItems PurchaseOrderItem[]
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
}

model Order {
  id            String      @id @default(cuid())
  invoiceNumber String      @unique // رقم الفاتورة/عرض السعر التسلسلي
  isQuotation   Boolean     @default(false) // تحديد إذا كان عرض سعر أو فاتورة نهائية
  customerName  String?     // اسم العميل/الشركة (مثال: المقاولون العرب)
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  totalAmount   Float       // المجموع قبل الضريبة
  taxAmount     Float       // قيمة الضريبة
  netAmount     Float       // الإجمالي الصافي شامل الضريبة
  qrCode        String?     // رمز الاستجابة السريعة المشفر
  status        String      @default("COMPLETED") // "COMPLETED" | "DRAFT" | "CANCELLED"
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Customer {
  id             String   @id @default(cuid())
  name           String   @unique // اسم العميل/الشركة
  location       String?  // الموقع
  buildingsCount Int      @default(0) // عدد العماير
  cr             String?  // السجل التجاري
  trn            String?  // الرقم الضريبي للعميل
  customerType   String   @default("CASH") // طبيعة العميل: "CASH" (نقدي) | "CREDIT" (آجل)
  phone          String?  // رقم التلفون
  discount       Float    @default(0) // نسبة الخصم
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
  payments       Payment[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  taxAmount Float
  total     Float
}

model Bank {
  id            String           @id @default(cuid())
  name          String           @unique
  accountNumber String?
  balance       Float            @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  payments      Payment[]
  expenses      ExpensePayment[]
}

model Payment {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  bankId        String
  bank          Bank     @relation(fields: [bankId], references: [id])
  amount        Float
  reference     String?
  receiptNumber String?  // رقم تسلسلي للمقبوضات
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Supplier {
  id             String           @id @default(cuid())
  name           String           @unique // اسم المورد
  phone          String?          // رقم الهاتف
  address        String?          // العنوان
  cr             String?          // السجل التجاري
  trn            String?          // الرقم الضريبي
  balance        Float            @default(0) // مديونية المورد (الرصيد المتبقي له)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  purchaseOrders PurchaseOrder[]
  expenses       ExpensePayment[]
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  billNumber    String              @unique // رقم فاتورة المشتريات/التوريد
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  totalAmount   Float               // الإجمالي قبل الضريبة
  taxAmount     Float               // قيمة الضريبة
  netAmount     Float               // الإجمالي الصافي شامل الضريبة
  date          DateTime            @default(now())
  items         PurchaseOrderItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           // الكمية الواردة
  unitCost        Float         // سعر التكلفة للوحدة
  taxAmount       Float
  total           Float
}

model ExpensePayment {
  id            String   @id @default(cuid())
  expenseNumber String   @unique // رقم سند الصرف التسلسلي (مثال: EXP-2026-0001)
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  bankId        String
  bank          Bank     @relation(fields: [bankId], references: [id])
  amount        Float    // قيمة المبلغ المصروف
  reference     String?
  date          DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
